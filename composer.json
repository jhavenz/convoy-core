{
  "name": "convoy/core",
  "description": "Sane async for PHP 8.4+",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "async",
    "concurrency",
    "fibers",
    "reactphp",
    "promises",
    "parallel",
    "event-loop"
  ],
  "homepage": "https://github.com/jhavenz/convoy-core",
  "authors": [
    {
      "name": "Jonathan Havens",
      "email": "mail@jhavens.tech"
    }
  ],
  "require": {
    "php": ">=8.4",
    "react/async": "^4.3",
    "react/promise": "^3.2",
    "react/event-loop": "^1.5"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0",
    "react/http": "^1.10",
    "react/promise-timer": "^1.11",
    "rector/rector": "^2.0",
    "slevomat/coding-standard": "^8.15",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "scripts": {
    "rector": "rector process",
    "rector:dry": "rector process --dry-run",
    "cs": "phpcs",
    "cs:fix": "phpcbf",
    "test": "php vendor/bin/phpunit"
  },
  "suggest": {
    "react/http": "Required for HttpRunner and ConvoyHttpRunner",
    "spatie/backtrace": "Enhanced stack traces",
    "symfony/runtime": "For symfony/runtime integration with ConvoyRuntime",
    "symfony/dotenv": "For .env file support with symfony/runtime"
  },
  "autoload": {
    "psr-4": {
      "Convoy\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Convoy\\Tests\\": "tests/"
    },
    "classmap": [
      "tests/Support/Fixtures/"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
